# ============================================================================
# 论文评审系统 - 敏感信息配置
# ============================================================================
# 说明：
# 1. 此文件只包含敏感信息（API密钥、Token等）
# 2. 非敏感配置（模型名称、服务地址等）请在 config/settings.json 中修改
# 3. 复制此文件为 .env 并填写实际值
# 4. .env 文件不要提交到 Git

# ----------------------------------------------------------------------------
# 云端API密钥 (必填)
# ----------------------------------------------------------------------------
# 获取方式: 访问 https://dashscope.console.aliyun.com/ 获取
CLOUD_API_KEY=sk-your-cloud-api-key-here

# ----------------------------------------------------------------------------
# MinerU API Token (必填)
# ----------------------------------------------------------------------------
# 获取方式: 访问 https://mineru.net 注册账号获取
MINERU_TOKEN=Bearer-your-mineru-token-here

# ----------------------------------------------------------------------------
# 可选配置
# ----------------------------------------------------------------------------

# 如需使用加密配置文件而非环境变量，可运行:
# python create_config.py
# 然后在此处设置加密密码提示将被使用

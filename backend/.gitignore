# ============================================================================
# 敏感信息 - 不提交到Git
# ============================================================================

# 环境变量文件（包含API密钥、Token等）
.env
.env.local
.env.*.local

# 加密配置目录
.config/

# ============================================================================
# Python
# ============================================================================

__pycache__/
*.py[cod]
*.so
*.pyc
.venv/
venv/
env/
*.egg-info/
dist/
build/

# ============================================================================
# 运行时数据 - 不提交
# ============================================================================

# 数据目录
data/
uploads/
database_*/
user_*/
result/
chunks/
mineru_output/

# 用户数据
registered_users.json

# ============================================================================
# 大文件 - 不提交
# ============================================================================

*.pkl
*.pth
*.bin
*.safetensors
*.ckpt
*.pt

# ============================================================================
# 日志 - 不提交
# ============================================================================

*.log
logs/
nohup.out

# ============================================================================
# IDE和编辑器
# ============================================================================

.vscode/
.idea/
*.swp
*.swo
*~
.project
.pydevproject

# ============================================================================
# 操作系统
# ============================================================================

.DS_Store
Thumbs.db
desktop.ini

# ============================================================================
# 可提交的配置文件
# ============================================================================
# settings.json - 非敏感配置，可以提交
# .env.example - 环境变量模板，可以提交
# .gitignore - 本文件
# requirements.txt - Python依赖
# ============================================================================

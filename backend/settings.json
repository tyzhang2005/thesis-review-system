{
  "_comment": "论文评审系统配置文件 - 非敏感信息可提交到代码库",
  "version": "1.0.0",

  "api": {
    "use_cloud": true,
    "use_vllm": true,
    "max_concurrent": 32,

    "cloud": {
      "endpoint": "https://dashscope.aliyuncs.com/compatible-mode",
      "model": "deepseek-v3.2-exp",
      "embedding": {
        "endpoint": "https://dashscope.aliyuncs.com/compatible-mode/v1/embeddings",
        "model": "text-embedding-v4",
        "dimension": 2048
      }
    },

    "vllm": {
      "host": "http://localhost:8003",
      "embedding_endpoint": "http://localhost:8004/v1/embeddings"
    },

    "ollama": {
      "host": "http://localhost:11434"
    }
  },

  "models": {
    "aigc_detector_path": "./models/AIGC_text_detector",
    "use_cloud_embedding": true
  },

  "paths": {
    "user_result_advice": "./data/user_result",
    "display_data": "./data/display"
  },

  "pdf": {
    "convert_method": "local",
    "mineru": {
      "api_base": "https://mineru.net/api/v4"
    }
  },

  "upload": {
    "max_file_size_mb": 50,
    "sub_limit": 3
  },

  "vectorstore": {
    "local_dir": "databases/vectorstore_local",
    "cloud_dir": "databases/vectorstore_cloud",
    "user_result_local_dir": "databases/user_result_local",
    "user_result_cloud_dir": "databases/user_result_cloud",
    "collection_prefix": {
      "local": "local_4b",
      "cloud": "cloud_4b"
    }
  },

  "cors": {
    "origins": [
      "http://localhost:3000",
      "http://localhost:5173",
      "http://127.0.0.1:3000"
    ],
    "allow_credentials": true,
    "allow_methods": ["*"],
    "allow_headers": ["*"]
  },

  "server": {
    "host": "0.0.0.0",
    "port": 8000
  }
}
